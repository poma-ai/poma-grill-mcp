{
  "name": "@poma-ai/poma-grill-mcp",
  "version": "0.3.0",
  "description": "MCP server for the POMA Grill context engine API (Node/TypeScript implementation)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "poma-grill-mcp": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc && node scripts/copy-schemas.mjs",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit --project tsconfig.test.json",
    "smoke": "npm run build && tsx test/smoke.ts",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0"
  },
  "devDependencies": {
    "@types/node": "25.6.1",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  },
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/poma-ai/poma-grill-mcp.git",
    "directory": "node"
  }
}
